tpDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"验证码验证成功\"\r\n          },\r\n          \"400\": {\r\n            \"description\": \"验证码错误或已过期\"\r\n          },\r\n          \"404\": {\r\n            \"description\": \"验证码不存在\"\r\n          },\r\n          \"500\": {\r\n            \"description\": \"服务器内部错误\"\r\n          }\r\n        },\r\n        \"summary\": \"验证OTP验证码\",\r\n        \"tags\": [\r\n          \"otp\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/otp/status\": {\r\n      \"post\": {\r\n        \"description\": \"获取指定手机号的OTP验证码状态\",\r\n        \"operationId\": \"OtpController_getOtpStatus\",\r\n        \"parameters\": [],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"获取状态成功\"\r\n          }\r\n        },\r\n        \"summary\": \"获取OTP状态\",\r\n        \"tags\": [\r\n          \"otp\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/sessions/my-sessions\": {\r\n      \"post\": {\r\n        \"description\": \"获取当前用户的所有活跃会话信息\",\r\n        \"operationId\": \"SessionsController_getMySessions\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/GetSessionsDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"获取成功\",\r\n            \"content\": {\r\n              \"application/json\": {\r\n                \"schema\": {\r\n                  \"properties\": {\r\n                    \"code\": {\r\n                      \"example\": 200\r\n                    },\r\n                    \"data\": {\r\n                      \"example\": \"object\",\r\n                      \"type\": \"object\"\r\n                    },\r\n