    },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"管理员分页查询所有会话\",\r\n        \"tags\": [\r\n          \"admin-sessions\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/admin/sessions/stats\": {\r\n      \"get\": {\r\n        \"description\": \"管理员获取系统所有会话的统计信息\",\r\n        \"operationId\": \"AdminSessionsController_getSessionStats\",\r\n        \"parameters\": [],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"获取成功\"\r\n          },\r\n          \"401\": {\r\n            \"description\": \"未授权\"\r\n          },\r\n          \"403\": {\r\n            \"description\": \"权限不足\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"管理员获取会话统计信息\",\r\n        \"tags\": [\r\n          \"admin-sessions\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/admin/sessions/logout/{sessionId}\": {\r\n      \"delete\": {\r\n        \"description\": \"管理员强制踢出指定的会话\",\r\n        \"operationId\": \"AdminSessionsController_adminLogoutSession\",\r\n        \"parameters\": [\r\n          {\r\n            \"name\": \"sessionId\",\r\n            \"required\": true,\r\n            \"in\": \"path\",\r\n            \"schema\": {\r\n              \"type\": \"string\"\r\n            }\r\n          }\r\n        ],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"登出成功\"\r\n          },\r\n          \"401\": {\r\n            \"description\": \"未授权\"\r\n          },\r\n          \"403\": {\r\n            \"description\": \"权限不足\"\r\n          },\r\n          \"404\": {\r\n            \"description\": \"会话不存在\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"管理员踢出指定会话\",\r\n        \"tags\": [\r\n          \"admin-sessions\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/admin/sessions/logout-user/{userId}/{subjectType}\": {\r\n      \"delete\": {\r\n        \"description\": \"管理员强制踢出指定用户的所有会话\",\r\n        \"operationId\": \"AdminSessionsController_adminLogoutAllUserSessions\",\r\n        \"parameters\": [\r\n          {\r\n            \"name\": \"userId\",\r\n            \"required\": true,\r\n            \"in\": \"path\",\r\n            \"schema\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          {\r\n            \"name\": \"subjectType\",\r\n            \"required\": true,\r\n            \"in\": \"path\",\r\n            \"schema\": {\r\n              \"type\": \"string\"\r\n            }\r\n          }\r\n        ],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"登出成功\",\r\n            \"content\": {\r\n              \"application/json\": {\r\n                \"schema\": {\r\n                  \"properties\": {\r\n                    \"code\": {\r\n                      \"example\": 200\r\n                    },\r\n                    \"data\": {\r\n                      \"example\": \"object\",\r\n                      \"type\": \"object\"\r\n                    },\r\n                    \"message\": {\r\n                      \"example\": \"操作成功\"\r\n                    },\r\n                    \"requestId\": {\r\n                      \"example\": \"f5a7b9c8-1234-5678-90ab-cdef12345678\"\r\n                    },\r\n                    \"timestamp\": {\r\n                      \"example\": 1735000000000\r\n                    }\r\n                  }\r\n                }\r\n              }\r\n            }\r\n          },\r\n          \"401\": {\r\n            \"description\": \"未授权\"\r\n          },\r\n          \"403\": {\r\n            \"description\": \"权限不足\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"管理员踢出用户所有会话\",\r\n        \"tags\": [\r\n          \"admin-sessions\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/admin/sessions/disable-user/{userId}/{subjectType}\": {\r\n      \"delete\": {\r\n        \"description\": \"管理员先强制登出用户所有会话，再禁用用户账户\",\r\n        \"operationId\": \"AdminSessionsController_adminDisableUserAccount\",\r\n        \"parameters\": [\r\n          {\r\n            \"name\": \"userId\",\r\n            \"required\": true,\r\n            \"in\": \"path\",\r\n            \"schema\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          {\r\n            \"name\": \"subjectType\",\r\n            \"required\": true,\r\n            \"in\": \"path\",\r\n            \"schema\": {\r\n              \"type\": \"string\"\r\n            }\r\n          }\r\n        ],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"禁用成功\",\r\n            \"content\": {\r\n              \"application/json\": {\r\n                \"schema\": {\r\n                  \"properties\": {\r\n                    \"code\": {\r\n                      \"example\": 200\r\n                    },\r\n                    \"data\": {\r\n                      \"example\": \"object\",\r\n                      \"type\": \"object\"\r\n                    },\r\n                    \"message\": {\r\n                      \"example\": \"操作成功\"\r\n                    },\r\n                    \"requestId\": {\r\n                      \"example\": \"f5a7b9c8-1234-5678-90ab-cdef12345678\"\r\n                    },\r\n                    \"timestamp\": {\r\n                      \"example\": 1735000000000\r\n                    }\r\n                  }\r\n                }\r\n              }\r\n            }\r\n          },\r\n          \"401\": {\r\n            \"description\": \"未授权\"\r\n          },\r\n          \"403\": {\r\n            \"description\": \"权限不足\"\r\n          },\r\n          \"404\": {\r\n            \"description\": \"用户不存在\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"管理员禁用用户账户\",\r\n        \"tags\": [\r\n          \"admin-sessions\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/admin/sessions/logout-by-criteria\": {\r\n      \"post\": {\r\n        \"description\": \"管理员根据条件批量踢出符合条件的会话\",\r\n        \"operationId\": \"AdminSessionsController_logoutSessionsByCriteria\",\r\n        \"parameters\": [],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"登出成功\",\r\n            \"content\": {\r\n              \"application/json\": {\r\n                \"schema\": {\r\n                  \"properties\": {\r\n                    \"code\": {\r\n                      \"example\": 200\r\n                    },\r\n                    \"data\": {\r\n                      \"example\": \"object\",\r\n                      \"type\": \"object\"\r\n                    },\r\n                    \"message\": {\r\n                      \"example\": \"操作成功\"\r\n                    },\r\n                    \"requestId\": {\r\n                      \"example\": \"f5a7b9c8-1234-5678-90ab-cdef12345678\"\r\n                    },\r\n                    \"timestamp\": {\r\n                      \"example\": 1735000000000\r\n                    }\r\n                  }\r\n                }\r\n              }\r\n            }\r\n          },\r\n          \"401\": {\r\n            \"description\": \"未授权\"\r\n          },\r\n          \"403\": {\r\n            \"description\": \"权限不足\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"管理员按条件批量踢出会话\",\r\n        \"tags\": [\r\n          \"admin-sessions\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/set\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_set\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheSetDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"缓存设置成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"设置缓存值\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/get\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_get\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheGetDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"获取缓存成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"获取缓存值\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/delete\": {\r\n      \"delete\": {\r\n        \"operationId\": \"CacheTestController_delete\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheDeleteDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"缓存删除成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"删除缓存\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/exists\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_exists\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheExistsDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"检查完成\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"检查缓存是否存在\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/increment\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_increment\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheIncrementDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"递增成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"递增缓存值\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/decrement\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_decrement\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheIncrementDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"递减成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"递减缓存值\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/info\": {\r\n      \"get\": {\r\n        \"operationId\": \"CacheTestController_info\",\r\n        \"parameters\": [],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"获取信息成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"获取缓存信息\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/flush\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_flush\",\r\n        \"parameters\": [],\r\n        \"requestBody\": {\r\n          \"required\": true,\r\n          \"content\": {\r\n            \"application/json\": {\r\n              \"schema\": {\r\n                \"$ref\": \"#/components/schemas/CacheFlushDto\"\r\n              }\r\n            }\r\n          }\r\n        },\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"缓存清空成功\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"清空缓存\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    },\r\n    \"/api/cache-test/test-complex\": {\r\n      \"post\": {\r\n        \"operationId\": \"CacheTestController_testComplexData\",\r\n        \"parameters\": [],\r\n        \"responses\": {\r\n          \"200\": {\r\n            \"description\": \"复杂数据类型测试完成\"\r\n          }\r\n        },\r\n        \"security\": [\r\n          {\r\n            \"bearer\": []\r\n          }\r\n        ],\r\n        \"summary\": \"测试复杂数据类型缓存\",\r\n        \"tags\": [\r\n          \"cache-test\"\r\n        ]\r\n      }\r\n    }\r\n  },\r\n  \"info\": {\r\n    \"title\": \"Simple Store API\",\r\n    \"description\": \"The Simple Store API description\",\r\n    \"version\": \"1.0\",\r\n    \"contact\": {}\r\n  },\r\n  \"tags\": [],\r\n  \"servers\": [],\r\n  \"components\": {\r\n    \"securitySchemes\": {\r\n      \"bearer\": {\r\n        \"scheme\": \"bearer\",\r\n        \"bearerFormat\": \"JWT\",\r\n        \"type\": \"http\"\r\n      }\r\n    },\r\n    \"schemas\": {\r\n      \"AuthMemberDto\": {\r\n        \"type\": \"object\",\r\n        \"properties\": {\r\n          \"phone\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"手机号\",\r\n            \"example\": \"13800000000\"\r\n          },\r\n          \"password\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"密码（与验证码、Passkey三选一）\",\r\n            \"example\": \"13800000000\"\r\n          },\r\n          \"otpCode\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"OTP验证码（可选，如果启用OTP验证则需要提供）\",\r\n            \"example\": \"123456\"\r\n          },\r\n          \"passkey\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Passkey认证数据（与密码、OTP验证码三选一）\",\r\n            \"example\": \"\"\r\n          }\r\n        },\r\n        \"required\": [\r\n          \"phone\"\r\n        ]\r\n      },\r\n      \"AuthCommunityStaffDto\": {\r\n        \"type\": \"object\",\r\n        \"properties\": {\r\n          \"phone\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"手机号\",\r\n            \"example\": \"13800000000\"\r\n 