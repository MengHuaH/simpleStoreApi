# Docker 环境配置

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=app_user
DB_PASSWORD=app_password
DB_DATABASE=simple_store

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=simple-store:

# 缓存TTL配置（单位：秒）
CACHE_DEFAULT_TTL=3600
CACHE_SHORT_TTL=300
CACHE_LONG_TTL=86400

# JWT配置
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=3600

# 应用配置
NODE_ENV=production
PORT=3000

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# 其他配置
API_PREFIX=/api